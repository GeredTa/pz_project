<UserControl x:Class="Monitor_kl2.Views.MonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:local ="clr-namespace:Monitor_kl2"
             >

    <UserControl.Resources>
        <local:HostStatusToColorConverter x:Key="StatusConverter" />
    </UserControl.Resources>
    <DockPanel>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" />
        <StackPanel  Margin="5" Orientation="Horizontal" DockPanel.Dock="Top">
            <TextBlock Text="Liczba widocznych hostów" ></TextBlock>
            <xctk:DecimalUpDown Margin="5 0 0 0" Value="{Binding NumberOfVisibleHosts}" />
        </StackPanel>
        <DataGrid Name="HostList">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" >
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{Binding CurrentStatus, Converter={StaticResource StatusConverter}}" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </DockPanel>
</UserControl>
